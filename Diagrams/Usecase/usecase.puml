@startuml FaceDetectDemo_Usecase
title FaceDetectDemo — Use Case Overview

skinparam shadowing false
skinparam handwritten false
skinparam packageStyle rectangle
skinparam roundcorner 8

skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #F57F17
  FontColor #333333
}

skinparam rectangle {
  BackgroundColor #FAFAFA
  BorderColor #546E7A
}

skinparam note {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

left to right direction

actor User as User

rectangle "FaceDetectDemo Project" {
  package "Choose Image" #E1F5FE {
    usecase "Provide Photograph" as UC_Provide
  }

  package "Choose Engine" #F3E5F5 {
    usecase "Choose Detection Approach" as UC_Choose
    usecase "Detect Faces" as UC_Detect
    usecase "Switch Comparison View" as UC_Switch
  }

  package "Comparison Results" #E8EAF6 {
    usecase "Browse Face Results" as UC_Browse
    usecase "Inspect Face Detail" as UC_Inspect
  }

  package "Messages" #FFF3E0 {
    usecase "Receive System Feedback" as UC_Feedback
  }
}

User --> UC_Provide
User --> UC_Choose
User --> UC_Detect
User --> UC_Switch
User --> UC_Browse
User --> UC_Inspect
User --> UC_Feedback

UC_Detect .> UC_Provide : <<include>>
UC_Detect .> UC_Choose : <<include>>

UC_Inspect .> UC_Browse : <<extend>>

UC_Feedback .> UC_Detect : <<extend>>

note right of UC_Feedback
  Optional notices after attempting detection
  (for example missing input, no faces found,
  or configuration not ready).
end note

note bottom of UC_Inspect
  Optional: open a single face when reviewing results.
end note

@enduml
